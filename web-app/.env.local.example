# ============================================================
# Opus8 Platform — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# DeepSeek API (used by central proxy)
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# Central Domain for Desktop App routing
NEXT_PUBLIC_CENTRAL_DOMAIN="https://yourcentraldomain.com"

# App Config
NEXT_PUBLIC_APP_NAME="Opus8"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
