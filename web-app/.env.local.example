# ============================================================
# Opus8 Platform — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# DeepSeek API (used by central proxy for Claude Opus 8 models)
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# Google AI API (used by central proxy for Gemini models)
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"

# Central Domain for Desktop App routing
NEXT_PUBLIC_CENTRAL_DOMAIN="https://yourcentraldomain.com"

# App Config
NEXT_PUBLIC_APP_NAME="Opus8"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
